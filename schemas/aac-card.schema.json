{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AnkitClassicVision/agent-automation-creator/schemas/aac-card.schema.json",
  "title": "AAC Card Schema v2.1",
  "description": "AAC 2.1 card contract for workflow, node, agent-envelope, and tool artifacts. Adds Tool Reality + Harness Maintenance fields while preserving the AAC v1.1 core rubric.",
  "oneOf": [
    {
      "$ref": "#/$defs/workflow_card"
    },
    {
      "$ref": "#/$defs/node_card"
    },
    {
      "$ref": "#/$defs/agent_card"
    },
    {
      "$ref": "#/$defs/tool_card"
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_array": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "discipline_set": {
      "type": "object",
      "required": [
        "bounded",
        "grounded",
        "gated",
        "observed",
        "governed"
      ],
      "properties": {
        "bounded": {
          "type": "object"
        },
        "grounded": {
          "type": "object"
        },
        "gated": {
          "type": "object"
        },
        "observed": {
          "type": "object"
        },
        "governed": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "owner_set": {
      "type": "object",
      "required": [
        "process_owner",
        "technical_owner",
        "residue_accepter",
        "reviewer"
      ],
      "properties": {
        "process_owner": {
          "$ref": "#/$defs/non_empty_string"
        },
        "technical_owner": {
          "$ref": "#/$defs/non_empty_string"
        },
        "residue_accepter": {
          "$ref": "#/$defs/non_empty_string"
        },
        "reviewer": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "additionalProperties": true
    },
    "workflow_card": {
      "type": "object",
      "required": [
        "card_type",
        "aac_card_version",
        "workflow_id",
        "workflow_box",
        "control_topology",
        "value_mode",
        "cost_framing",
        "trigger",
        "finished_state",
        "sinks",
        "owners",
        "max_lane",
        "nodes",
        "agents",
        "hard_refuse",
        "observability",
        "residue",
        "escalation_path",
        "aac_sync_contract",
        "maintenance_contract"
      ],
      "properties": {
        "card_type": {
          "const": "workflow"
        },
        "aac_card_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "workflow_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "workflow_box": {
          "$ref": "#/$defs/non_empty_string"
        },
        "control_topology": {
          "enum": [
            "unit",
            "graph_directed",
            "agent_directed_envelope",
            "hybrid"
          ]
        },
        "value_mode": {
          "enum": [
            "replace",
            "augment",
            "extend"
          ]
        },
        "trigger": {
          "$ref": "#/$defs/non_empty_string"
        },
        "finished_state": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sinks": {
          "type": "object",
          "required": [
            "happy",
            "refuse",
            "hard_refuse"
          ],
          "properties": {
            "happy": {
              "$ref": "#/$defs/non_empty_string"
            },
            "refuse": {
              "$ref": "#/$defs/non_empty_string"
            },
            "hard_refuse": {
              "$ref": "#/$defs/non_empty_string"
            }
          },
          "additionalProperties": true
        },
        "owners": {
          "$ref": "#/$defs/owner_set"
        },
        "max_lane": {
          "$ref": "#/$defs/non_empty_string"
        },
        "nodes": {
          "$ref": "#/$defs/non_empty_array"
        },
        "agents": {
          "$ref": "#/$defs/non_empty_array"
        },
        "hard_refuse": {
          "$ref": "#/$defs/non_empty_array"
        },
        "observability": {
          "type": "object"
        },
        "residue": {
          "type": "object"
        },
        "escalation_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "cost_framing": {
          "type": "object",
          "required": [
            "cost_of_failure",
            "cost_of_inaction",
            "per_error_cost_band"
          ],
          "properties": {
            "cost_of_failure": {
              "$ref": "#/$defs/non_empty_string"
            },
            "cost_of_inaction": {
              "$ref": "#/$defs/non_empty_string"
            },
            "per_error_cost_band": {
              "$ref": "#/$defs/non_empty_string"
            }
          },
          "additionalProperties": true
        },
        "aac_sync_contract": {
          "$ref": "#/$defs/aac_sync_contract"
        },
        "maintenance_contract": {
          "$ref": "#/$defs/maintenance_contract"
        }
      },
      "additionalProperties": true
    },
    "node_card": {
      "type": "object",
      "required": [
        "card_type",
        "aac_card_version",
        "workflow",
        "node_id",
        "runtime_mode",
        "max_lane",
        "owner",
        "input_contract",
        "output_contract",
        "data_classification",
        "disciplines",
        "gates",
        "hard_refuse",
        "telemetry",
        "kill_switch",
        "tool_pool_contract",
        "tool_reality_gate"
      ],
      "properties": {
        "card_type": {
          "const": "node"
        },
        "aac_card_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "workflow": {
          "$ref": "#/$defs/non_empty_string"
        },
        "node_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "runtime_mode": {
          "enum": [
            "D",
            "C",
            "A",
            "H"
          ]
        },
        "max_lane": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner": {
          "$ref": "#/$defs/non_empty_string"
        },
        "input_contract": {
          "type": "object"
        },
        "output_contract": {
          "type": "object"
        },
        "data_classification": {
          "$ref": "#/$defs/non_empty_string"
        },
        "disciplines": {
          "$ref": "#/$defs/discipline_set"
        },
        "gates": {
          "type": "object",
          "required": [
            "input",
            "output",
            "cross_check",
            "action"
          ],
          "properties": {
            "input": {
              "type": "object"
            },
            "output": {
              "type": "object"
            },
            "cross_check": {
              "type": "object"
            },
            "action": {
              "type": "object"
            }
          },
          "additionalProperties": true
        },
        "hard_refuse": {
          "$ref": "#/$defs/non_empty_array"
        },
        "telemetry": {
          "type": "object"
        },
        "kill_switch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "tool_pool_contract": {
          "$ref": "#/$defs/tool_pool_contract"
        },
        "tool_reality_gate": {
          "$ref": "#/$defs/tool_reality_gate"
        }
      },
      "additionalProperties": true
    },
    "agent_card": {
      "type": "object",
      "required": [
        "card_type",
        "aac_card_version",
        "agent_id",
        "purpose",
        "allowed_workflows",
        "allowed_nodes",
        "tools",
        "allowed_action_classes",
        "forbidden_action_classes",
        "approval_required_actions",
        "memory_policy",
        "telemetry_required",
        "kill_switch",
        "owner",
        "residue_accepter",
        "disciplines",
        "tool_pool_contract",
        "tool_reality_gate"
      ],
      "properties": {
        "card_type": {
          "const": "agent"
        },
        "aac_card_version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "agent_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "purpose": {
          "$ref": "#/$defs/non_empty_string"
        },
        "allowed_workflows": {
          "$ref": "#/$defs/non_empty_array"
        },
        "allowed_nodes": {
          "$ref": "#/$defs/non_empty_array"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "allowed_action_classes": {
          "$ref": "#/$defs/non_empty_array"
        },
        "forbidden_action_classes": {
          "$ref": "#/$defs/non_empty_array"
        },
        "approval_required_actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "memory_policy": {
          "enum": [
            "none",
            "read_only",
            "proposal_only",
            "approved_write"
          ]
        },
        "telemetry_required": {
          "type": "boolean"
        },
        "kill_switch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "owner": {
          "$ref": "#/$defs/non_empty_string"
        },
        "residue_accepter": {
          "$ref": "#/$defs/non_empty_string"
        },
        "disciplines": {
          "$ref": "#/$defs/discipline_set"
        },
        "tool_pool_contract": {
          "$ref": "#/$defs/tool_pool_contract"
        },
        "tool_reality_gate": {
          "$ref": "#/$defs/tool_reality_gate"
        }
      },
      "additionalProperties": true
    },
    "aac_sync_contract": {
      "type": "object",
      "required": [
        "schema_version",
        "aac_operating_package_version",
        "aac_core_rubric_version",
        "aac_factory_version",
        "capability_set",
        "drift_policy",
        "canonical_fields"
      ],
      "additionalProperties": true
    },
    "maintenance_contract": {
      "type": "object",
      "required": [
        "schema_version",
        "workflow_id",
        "current_job_sentence",
        "owner",
        "technical_owner",
        "residue_accepter",
        "approval_required_for",
        "maintenance_triggers",
        "replay_pack_ref",
        "run_card_ref",
        "update_proposals_ref",
        "rollback_plan",
        "autonomous_self_update_allowed"
      ],
      "additionalProperties": true
    },
    "tool_pool_contract": {
      "type": "object",
      "required": [
        "schema_version",
        "node_id",
        "runtime_mode",
        "max_lane",
        "allowed_tools",
        "forbidden_tools_by_default",
        "approval_required_for_tool_changes"
      ],
      "additionalProperties": true
    },
    "tool_reality_gate": {
      "type": "object",
      "required": [
        "schema_version",
        "node_id",
        "status",
        "proof_status",
        "fable_tool_proof_run_ref",
        "tool_change_rule"
      ],
      "additionalProperties": true
    },
    "tool_card": {
      "type": "object",
      "required": [
        "card_type",
        "tool_id",
        "name",
        "responsibility",
        "input_schema",
        "output_schema",
        "side_effect_profile",
        "permission_tier",
        "max_lane_allowed",
        "proof_status",
        "owner",
        "audit_log_path",
        "rollback_or_reversal"
      ],
      "properties": {
        "card_type": {
          "const": "tool"
        }
      },
      "additionalProperties": true
    }
  }
}
