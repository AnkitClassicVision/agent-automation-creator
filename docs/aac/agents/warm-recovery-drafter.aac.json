{
  "card_type": "agent",
  "aac_card_version": "2.1",
  "agent_id": "warm-recovery-drafter",
  "purpose": "Create draft-only warm recovery review packets for human approval without sending messages or mutating CRM state.",
  "allowed_workflows": [
    "warm-recovery-draft-only"
  ],
  "allowed_nodes": [
    "warm-recovery-ingest-candidate",
    "warm-recovery-classify-intent",
    "warm-recovery-draft-followup"
  ],
  "tools": [
    {
      "name": "approved_source_reader",
      "scope": "read approved source snapshots",
      "write": false,
      "tool_id": "approved-source-reader",
      "proof_status": "sandbox_proven"
    },
    {
      "name": "review_packet_writer",
      "scope": "write private review packet only",
      "write": true,
      "tool_id": "review-packet-writer",
      "proof_status": "sandbox_proven"
    }
  ],
  "allowed_action_classes": [
    "read",
    "recommend",
    "draft"
  ],
  "forbidden_action_classes": [
    "write_crm",
    "send",
    "pay",
    "delete",
    "label",
    "escalate_without_human"
  ],
  "approval_required_actions": [
    "send_sms",
    "send_email",
    "crm_mutation",
    "sequence_enrollment",
    "lifecycle_stage_change"
  ],
  "memory_policy": "proposal_only",
  "telemetry_required": true,
  "kill_switch": "disable warm-recovery-drafter profile or remove review_packet_writer permission",
  "owner": "Hermes/AAC builder",
  "residue_accepter": "Ankit for pilot only",
  "disciplines": {
    "bounded": {
      "allowed_action_classes": [
        "read",
        "recommend",
        "draft"
      ],
      "forbidden_action_classes": [
        "send",
        "write_crm",
        "pay",
        "delete"
      ],
      "ai_selects_action_class": false
    },
    "grounded": {
      "claims_must_cite_sources": true,
      "allowed_source_types": [
        "approved source snapshot",
        "run card"
      ]
    },
    "gated": {
      "tool_call_gate": "required",
      "external_write_gate": "human approval required",
      "escalation_gate": "required on low confidence"
    },
    "observed": {
      "log_tool_calls": true,
      "log_costs": true,
      "log_refusals": true,
      "log_external_actions": true
    },
    "governed": {
      "kill_switch": "disable warm-recovery-drafter profile or tool permission",
      "memory_write_policy": "proposal_only",
      "approval_owner": "Bre or named ops owner"
    }
  },
  "tool_pool_contract": {
    "schema_version": "2.1",
    "node_id": "warm-recovery-drafter",
    "runtime_mode": "agent-envelope",
    "max_lane": "draft",
    "allowed_tools": [
      {
        "tool_id": "approved-source-reader",
        "why_needed": "read approved source snapshots",
        "allowed_operations": [
          "read_snapshot"
        ],
        "forbidden_operations": [
          "write",
          "send",
          "mutate_crm"
        ],
        "max_lane": "read",
        "proof_required": true,
        "proof_status": "sandbox_proven"
      },
      {
        "tool_id": "review-packet-writer",
        "why_needed": "write private draft packet only",
        "allowed_operations": [
          "write_private_review_packet"
        ],
        "forbidden_operations": [
          "send",
          "write_crm",
          "sequence_enrollment"
        ],
        "max_lane": "draft",
        "proof_required": true,
        "proof_status": "sandbox_proven"
      }
    ],
    "forbidden_tools": [],
